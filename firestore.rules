rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.username is string && data.username.size() >= 2 && data.username.size() <= 64
        && data.email is string && data.email.size() <= 128
        && data.coins is number && data.coins >= 0
        && data.tier in ['bronze', 'silver', 'gold', 'platinum']
        && (data.avatarUrl is string ? data.avatarUrl.size() <= 500 : true)
        && (data.displayName is string ? data.displayName.size() <= 64 : true)
        && (data.bio is string ? data.bio.size() <= 500 : true)
        && (data.stats is map)
        && data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.amount is number
        && data.coins is number
        && data.type in ['earn', 'withdraw', 'bonus']
        && data.status in ['pending', 'completed', 'failed']
        && (data.description is string ? data.description.size() <= 200 : true)
        && data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return data.userId is string
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 500
        && data.read is bool
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().tier == 'bronze'
        && incoming().coins == 0;

      allow update: if isOwner(userId) && isValidId(userId)
        && isValidUser(incoming())
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['username', 'displayName', 'avatarUrl', 'bio', 'stats', 'lastLoginAt', 'isVerified', 'country', 'coins']))
        )
        && (incoming().username != existing().username ? existsAfter(/databases/$(database)/documents/usernames/$(incoming().username)) : true)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;
      
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) && isValidId(transactionId);
        allow create: if isOwner(userId) && isValidId(transactionId)
          && isValidTransaction(incoming())
          && incoming().createdAt == request.time
          && incoming().status == 'pending';
        allow update: if isOwner(userId) && isValidId(transactionId)
          && isValidTransaction(incoming())
          && (existing().status == 'pending' && incoming().status == 'failed' && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
          && incoming().userId == existing().userId;
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) && isValidId(notificationId);
        allow update: if isOwner(userId) && isValidId(notificationId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(userId) && isValidId(notificationId);
      }
    }

    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(username) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && isValidId(username) && existing().userId == request.auth.uid;
    }

    match /leaderboard/{entryId} {
      allow read: if isSignedIn() && isValidId(entryId);
      allow list: if isSignedIn();
    }

    match /test/connection {
      allow get: if isSignedIn();
    }
  }
}
