{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information, balances, and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "coins": { "type": "number", "description": "Virtual currency balance" },
        "tier": { "type": "string", "enum": ["bronze", "silver", "gold", "platinum"] },
        "bio": { "type": "string", "description": "User profile bio" },
        "stats": {
          "type": "object",
          "properties": {
            "gamesPlayed": { "type": "number" },
            "highestStreak": { "type": "number" },
            "totalQuests": { "type": "number" }
          }
        },
        "referrerId": { "type": "string", "description": "UID of the user who referred them" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" },
        "country": { "type": "string" },
        "walletAddress": { "type": "string", "description": "Connected cryptocurrency wallet address" },
        "referralCode": { "type": "string", "description": "Unique referral code for this user" }
      },
      "required": ["uid", "username", "coins", "tier", "createdAt", "referralCode"]
    },
    "ReferralCodeEntry": {
      "title": "Referral Code Entry",
      "description": "Mapping from referral code to owner UID.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "UsernameEntry": {
      "title": "Username Entry",
      "description": "Used to enforce unique usernames.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Records earnings and withdrawals.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["earn", "withdraw", "bonus"] },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "coins": { "type": "number" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "coins", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Flattened user data for global ranking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "totalEarnings": { "type": "number" },
        "coins": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "totalEarnings", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by UID"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions belonging to a user"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notifications"
    },
    "/leaderboard/{entryId}": {
      "schema": "LeaderboardEntry",
      "description": "Global leaderboard entries"
    },
    "/usernames/{username}": {
      "schema": "UsernameEntry",
      "description": "Unique usernames mapping to UIDs"
    },
    "/referral_codes/{code}": {
      "schema": "ReferralCodeEntry",
      "description": "Mapping from referral code to owner UID"
    }
  }
}
